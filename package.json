{
  "name": "protextify-frontendv2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "type-check": "tsc --noEmit",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html",
    "test:e2e": "node e2e/run-all.mjs",
    "test:e2e:smoke": "node e2e/smoke-home.mjs",
    "test:e2e:auth-login": "node e2e/auth-login.mjs",
    "test:e2e:auth": "node e2e/authenticated-flows.mjs",
    "test:e2e:critical": "node e2e/critical-flows.mjs",
    "test:perf:k6:home": "k6 run --summary-export=performance/results/home-summary.json --out json=performance/results/home-raw.ndjson performance/k6/home.browser.js",
    "test:perf:k6:auth": "k6 run --summary-export=performance/results/auth-summary.json --out json=performance/results/auth-raw.ndjson performance/k6/auth-login.browser.js",
    "test:perf:k6:run-all": "k6 run --summary-export=performance/results/run-all-summary.json --out json=performance/results/run-all-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:public": "k6 run -e K6_RUN_ALL_SUITE=public --summary-export=performance/results/k6-run-all-public-summary.json --out json=performance/results/k6-run-all-public-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:auth": "k6 run -e K6_RUN_ALL_SUITE=auth --summary-export=performance/results/k6-run-all-auth-summary.json --out json=performance/results/k6-run-all-auth-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:legacy": "k6 run -e K6_RUN_ALL_SUITE=legacy --summary-export=performance/results/k6-run-all-legacy-summary.json --out json=performance/results/k6-run-all-legacy-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:protected": "k6 run -e K6_RUN_ALL_SUITE=protected --summary-export=performance/results/k6-run-all-protected-summary.json --out json=performance/results/k6-run-all-protected-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:notfound": "k6 run -e K6_RUN_ALL_SUITE=notfound --summary-export=performance/results/k6-run-all-notfound-summary.json --out json=performance/results/k6-run-all-notfound-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:standalone": "k6 run -e K6_RUN_ALL_SUITE=standalone --summary-export=performance/results/k6-run-all-standalone-summary.json --out json=performance/results/k6-run-all-standalone-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:run-all:admin": "k6 run -e K6_RUN_ALL_SUITE=admin --summary-export=performance/results/k6-run-all-admin-summary.json --out json=performance/results/k6-run-all-admin-raw.ndjson performance/k6/run-all.browser.js",
    "test:perf:k6:authenticated-flows": "k6 run --summary-export=performance/results/authenticated-summary.json --out json=performance/results/authenticated-raw.ndjson performance/k6/authenticated-flows.browser.js",
    "test:perf:k6:critical": "k6 run --summary-export=performance/results/critical-summary.json --out json=performance/results/critical-raw.ndjson performance/k6/critical-flows.browser.js",
    "test:perf:k6:all": "npm run test:perf:k6:home && npm run test:perf:k6:auth && npm run test:perf:k6:run-all && npm run test:perf:k6:authenticated-flows && npm run test:perf:k6:critical"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@lexical/code": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/vite": "^4.2.4",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "lexical": "^0.44.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "selenium-webdriver": "^4.41.0",
    "vite": "^8.0.10"
  }
}
